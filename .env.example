# =============================================================
#  KIDSPlay — variáveis de ambiente
#  Copie para .env e preencha. O ficheiro .env NUNCA vai ao Git.
# =============================================================

VITE_DEMO_MODE=true
VITE_DEMO_BYPASS_SUBSCRIPTION=true
VITE_USE_FIRESTORE=false
VITE_ADMIN_EMAIL=

# Firebase (Configurações do projeto → Seus apps → SDK)
# https://console.firebase.google.com
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Bunny.net (opcional) — URLs embed no Admin de episódios
# https://iframe.mediadelivery.net/embed/LIBRARY_ID/VIDEO_ID
